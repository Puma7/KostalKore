[run]
branch = True
source = kostal_plenticore
omit =
    kostal_plenticore/coordinator.py
    kostal_plenticore/number.py
    kostal_plenticore/sensor.py
    kostal_plenticore/switch.py
    kostal_plenticore/modbus_client.py
    kostal_plenticore/modbus_coordinator.py
    kostal_plenticore/health_monitor.py
    kostal_plenticore/health_sensor.py
    kostal_plenticore/health_binary_sensor.py
    kostal_plenticore/fire_safety.py
    kostal_plenticore/fire_safety_entities.py
    kostal_plenticore/binary_sensor.py
    kostal_plenticore/modbus_button.py
    kostal_plenticore/modbus_number.py
    kostal_plenticore/modbus_test.py
    kostal_plenticore/mqtt_bridge.py
    kostal_plenticore/button.py

[report]
show_missing = True
exclude_lines =
    if isinstance\(device_id, tuple\)
    pragma: no cover
    if TYPE_CHECKING
    except ImportError
    WARNUNG: Externe Batteriesteuerung
    Modbus platform setup incomplete
    Modbus platform unload incomplete
    _feed_health_data
